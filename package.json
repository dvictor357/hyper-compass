{
  "name": "hyper-compass",
  "version": "0.1.0",
  "description": "Autonomous cross-chain smart money intelligence pipeline with AI-powered signal analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hyper-compass": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "dev": "bun src/index.tsx",
    "pipeline": "bun src/alpha-pipeline.ts",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "bun vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "author": "dvictor357",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "ink": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.104.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.19.17",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/react": "^18.3.28",
    "@vitest/coverage-v8": "^3.2.4",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
