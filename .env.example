# ── Provider Selection ──────────────────────────────────────
# "free" = open-source providers (DexScreener, Hyperliquid, etc.)
# "nansen" = Nansen CLI (requires nansen CLI installed)
DATA_PROVIDER=free

# ── AI Analysis ─────────────────────────────────────────────
OPENROUTER_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4

# ── DexScreener (no key needed) ─────────────────────────────
# Free, no auth required. ~300 req/min.

# ── Moralis (free tier: 3,000 calls/day) ────────────────────
# Sign up at https://admin.moralis.io
MORALIS_API_KEY=

# ── Arkham Intelligence (optional, wallet labels) ───────────
# Sign up at https://platform.arkhamintelligence.com
ARKHAM_API_KEY=

# ── 1inch (EVM swap execution, free tier) ───────────────────
# Sign up at https://dev.1inch.io
ONEINCH_API_KEY=

# ── Hyperliquid (no key needed) ─────────────────────────────
# Public API, no auth required.

# ── Jupiter (Solana swap, no key needed) ────────────────────
# Public API, no auth required.
SOLANA_WALLET=

# ── Smart Money Engine ──────────────────────────────────────
SMART_MONEY_SEED=true
SMART_MONEY_DB=data/smart-money.db

# ── Mock Mode (for development without API keys) ────────────
NANSEN_MOCK=true

# ── Telegram Bot (optional) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
